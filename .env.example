# App and service URLs
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4010
PORT=4010

# Data services (Docker defaults)
MONGODB_URI=mongodb://root:example@localhost:27017/credora?authSource=admin
REDIS_URL=redis://localhost:6380

# Authentication: generate long random values for production
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7
COOKIE_SECURE=false

# AI provider: mock works offline; all adapters are server/worker-only
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Object storage is optional in local development; reports otherwise use local metadata only
REPORT_STORAGE_DIR=./storage/reports

# Set to true only when intentionally allowing credentialed cross-site requests
ENABLE_CROSS_SITE_CREDENTIALS=false
