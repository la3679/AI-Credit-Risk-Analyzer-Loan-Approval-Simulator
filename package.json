{
  "name": "credora-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n web,api,worker -c cyan,green,magenta \"npm run dev -w @credora/web\" \"npm run dev -w @credora/api\" \"npm run dev -w @credora/worker\"",
    "dev:web": "npm run dev -w @credora/web",
    "dev:api": "npm run dev -w @credora/api",
    "dev:worker": "npm run dev -w @credora/worker",
    "build": "npm run build -w @credora/web && npm run build -w @credora/api && npm run build -w @credora/worker",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "seed": "npm run seed -w @credora/api",
    "seed:demo": "npm run seed:demo -w @credora/api",
    "db:reset": "npm run db:reset -w @credora/api"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
